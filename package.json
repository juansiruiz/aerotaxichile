{
  "name": "aerotaxichile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @aerotaxi/api build && pnpm --filter @aerotaxi/web build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @aerotaxi/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.13.1"
}
