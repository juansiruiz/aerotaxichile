{
  "name": "aerotaxichile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "deploy": "node deploy.mjs",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @aerotaxi/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "dependencies": {
    "next": "16.2.4",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "prettier": "^3.5.3",
    "ssh2": "^1.17.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.13.1"
}
