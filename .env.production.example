# ─── Variables de entorno PRODUCCIÓN — Hostinger VPS ──────────────────────
# Copiar a .env.production y completar con los valores reales.
# NO subir este archivo a git.

# ── Base de datos ───────────────────────────────────────────────────────────
POSTGRES_USER=aerotaxi
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE_32_CARS
POSTGRES_DB=aerotaxichile

# ── API ─────────────────────────────────────────────────────────────────────
# Generar JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_DE_AL_MENOS_64_CARS_GENERADO_ALEATORIAMENTE
ALLOWED_ORIGINS=https://aerotaxichile.cl,https://www.aerotaxichile.cl
API_BASE_URL=https://aerotaxichile.cl/api

# ── Web Push VAPID ──────────────────────────────────────────────────────────
# Generar: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CAMBIAR_POR_PUBLIC_KEY_GENERADA
VAPID_PRIVATE_KEY=CAMBIAR_POR_PRIVATE_KEY_GENERADA
VAPID_SUBJECT=mailto:admin@aerotaxichile.cl

# ── Web (inyectadas en build time) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://aerotaxichile.cl/api
NEXT_PUBLIC_WHATSAPP_NUMBER=56963552132
NEXT_PUBLIC_VAPID_PUBLIC_KEY=MISMA_PUBLIC_KEY_QUE_ARRIBA
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaXXXX_TU_KEY_DE_GOOGLE_MAPS
